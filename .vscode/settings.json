{
  "json.schemas": [
    {
      "fileMatch": [
        "/configs/vscode/settings.json"
      ],
      "url": "vscode://schemas/settings/user"
    },
    {
      "fileMatch": [
        "/configs/vscode/keybindings.json"
      ],
      "url": "vscode://schemas/keybindings"
    },
    {
      "fileMatch": [
        "/configs/vscode/snippets/*.json"
      ],
      "url": "vscode://schemas/snippets"
    }
  ]
}
