input {
    keyboard {
        xkb {
            layout "us,es"
            options "grp:alt_space_toggle"
        }
        numlock
    }
    touchpad {
        tap
        natural-scroll
    }
}

// Home Manager replaces this placeholder with the active host output file.
include "@niri_outputs_path@"

gestures {
    hot-corners
}

layout {
    background-color "transparent"
    // Small breathing room without making windows look detached from the screen.
    gaps 12
    center-focused-column "never"
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }
    default-column-width { proportion 0.5; }
    focus-ring {
        width 2
        active-color "#8f8f8f"
        inactive-color "#3f3f3f"
        urgent-color "#cc4444"
    }
    border {
        off
    }
    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
}

// Noctalia renders this file from the active wallpaper palette at runtime.
include "noctalia.kdl"

layer-rule {
    match namespace="^noctalia-backdrop"
    place-within-backdrop true
}

overview {
    workspace-shadow {
        off
    }
}

environment {
    XDG_CURRENT_DESKTOP "niri"
    QT_QPA_PLATFORM "wayland"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    TERMINAL "wezterm"
}

hotkey-overlay {
    skip-at-startup
}

prefer-no-csd
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

animations {
    workspace-switch {
        spring damping-ratio=0.80 stiffness=523 epsilon=0.0001
    }
    window-open {
        duration-ms 150
        curve "ease-out-expo"
    }
    window-close {
        duration-ms 150
        curve "ease-out-quad"
    }
    horizontal-view-movement {
        spring damping-ratio=0.85 stiffness=423 epsilon=0.0001
    }
    window-movement {
        spring damping-ratio=0.75 stiffness=323 epsilon=0.0001
    }
    window-resize {
        spring damping-ratio=0.85 stiffness=423 epsilon=0.0001
    }
    overview-open-close {
        spring damping-ratio=0.85 stiffness=800 epsilon=0.0001
    }
}

window-rule {
    match app-id=r#"^(com\.mitchellh\.ghostty|ghostty|org\.wezfurlong\.wezterm)$"#
    draw-border-with-background false
    focus-ring {
        off
    }
    background-effect {
        blur true
        noise 0.032
        saturation 1.25
        xray true
    }
}

blur {
    passes 4
    offset 3.0
    noise 0.032
    saturation 1.25
}

window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

window-rule {
    match app-id="dev.noctalia.Noctalia.Settings"
    open-floating true
    default-column-width { fixed 1080; }
    default-window-height { fixed 920; }
}

window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

debug {
    honor-xdg-activation-with-invalid-serial
}

binds {
    Mod+Shift+Slash hotkey-overlay-title="Show Shortcuts" { show-hotkey-overlay; }

    Mod+Return hotkey-overlay-title="Terminal" { spawn "wezterm"; }
    Mod+Shift+Return hotkey-overlay-title="Ghostty" { spawn "ghostty"; }
    Mod+Space hotkey-overlay-title="Launcher" { spawn-sh "noctalia msg panel-toggle launcher"; }
    Mod+S hotkey-overlay-title="Control Center" { spawn-sh "noctalia msg panel-toggle control-center"; }
    Mod+Comma hotkey-overlay-title="Noctalia Settings" { spawn-sh "noctalia msg settings-toggle"; }
    Mod+V hotkey-overlay-title="Clipboard" { spawn-sh "noctalia msg panel-toggle clipboard"; }
    Mod+P hotkey-overlay-title="Session" { spawn-sh "noctalia msg panel-toggle session"; }
    Mod+Y hotkey-overlay-title="Wallpapers" { spawn-sh "noctalia msg panel-toggle wallpaper"; }
    Mod+N hotkey-overlay-title="Notifications" { spawn-sh "noctalia msg panel-toggle control-center notifications"; }
    Mod+M hotkey-overlay-title="System Monitor" { spawn-sh "noctalia msg panel-toggle control-center system"; }
    Mod+Alt+L hotkey-overlay-title="Lock" { spawn-sh "noctalia msg session lock"; }
    Ctrl+Alt+Delete repeat=false hotkey-overlay-title="System Monitor" { spawn "wezterm" "start" "--" "btop"; }
    Mod+F hotkey-overlay-title="Yazi" { spawn "wezterm" "start" "--" "yazi"; }
    Mod+E hotkey-overlay-title="Zed" { spawn "zeditor"; }
    Mod+B hotkey-overlay-title="Chrome" { spawn "google-chrome-stable"; }
    Mod+Alt+B repeat=false hotkey-overlay-title="Bitwarden Password" { spawn "rofi-rbw" "--selector" "wofi" "--clipboarder" "wl-copy" "--typer" "wtype" "--action" "copy" "--target" "password" "--clear-after" "45" "--prompt" "Copy password"; }
    Mod+Alt+U repeat=false hotkey-overlay-title="Bitwarden Username" { spawn "rofi-rbw" "--selector" "wofi" "--clipboarder" "wl-copy" "--typer" "wtype" "--action" "copy" "--target" "username" "--prompt" "Copy username"; }
    Mod+Alt+Shift+B repeat=false hotkey-overlay-title="Bitwarden Field" { spawn "rofi-rbw" "--selector" "wofi" "--clipboarder" "wl-copy" "--typer" "wtype" "--action" "copy" "--target" "menu" "--clear-after" "45" "--prompt" "Choose entry"; }

    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "noctalia msg volume-up"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "noctalia msg volume-down"; }
    XF86AudioMute allow-when-locked=true { spawn-sh "noctalia msg volume-mute"; }
    XF86AudioMicMute allow-when-locked=true { spawn-sh "noctalia msg mic-mute"; }
    XF86MonBrightnessUp allow-when-locked=true { spawn-sh "noctalia msg brightness-up"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn-sh "noctalia msg brightness-down"; }
    XF86AudioPlay allow-when-locked=true { spawn-sh "noctalia msg media toggle"; }
    XF86AudioPrev allow-when-locked=true { spawn-sh "noctalia msg media previous"; }
    XF86AudioNext allow-when-locked=true { spawn-sh "noctalia msg media next"; }
    Mod+Alt+J allow-when-locked=true hotkey-overlay-title="Volume Down" { spawn-sh "noctalia msg volume-down"; }
    Mod+Alt+K allow-when-locked=true hotkey-overlay-title="Volume Up" { spawn-sh "noctalia msg volume-up"; }
    Mod+Alt+M allow-when-locked=true hotkey-overlay-title="Mute" { spawn-sh "noctalia msg volume-mute"; }
    Mod+Alt+P allow-when-locked=true hotkey-overlay-title="Play/Pause" { spawn-sh "noctalia msg media toggle"; }
    Mod+Alt+Comma allow-when-locked=true hotkey-overlay-title="Previous Track" { spawn-sh "noctalia msg media previous"; }
    Mod+Alt+Period allow-when-locked=true hotkey-overlay-title="Next Track" { spawn-sh "noctalia msg media next"; }
    Mod+Alt+Minus allow-when-locked=true hotkey-overlay-title="Brightness Down" { spawn-sh "noctalia msg brightness-down"; }
    Mod+Alt+Equal allow-when-locked=true hotkey-overlay-title="Brightness Up" { spawn-sh "noctalia msg brightness-up"; }

    Mod+O repeat=false hotkey-overlay-title="Overview" { spawn "noctalia-overview"; }
    Mod+Tab repeat=false hotkey-overlay-title="Overview" { spawn "noctalia-overview"; }
    Mod+Q repeat=false hotkey-overlay-title="Close Window" { close-window; }
    Mod+H hotkey-overlay-title="Focus Left" { focus-column-left; }
    Mod+J hotkey-overlay-title="Focus Down" { focus-window-down; }
    Mod+K hotkey-overlay-title="Focus Up" { focus-window-up; }
    Mod+L hotkey-overlay-title="Focus Right" { focus-column-right; }
    Mod+Left hotkey-overlay-title="Focus Left" { focus-column-left; }
    Mod+Down hotkey-overlay-title="Focus Down" { focus-window-down; }
    Mod+Up hotkey-overlay-title="Focus Up" { focus-window-up; }
    Mod+Right hotkey-overlay-title="Focus Right" { focus-column-right; }

    Mod+Ctrl+H hotkey-overlay-title="Move Left" { move-column-left; }
    Mod+Ctrl+J hotkey-overlay-title="Move Down" { move-window-down; }
    Mod+Ctrl+K hotkey-overlay-title="Move Up" { move-window-up; }
    Mod+Ctrl+L hotkey-overlay-title="Move Right" { move-column-right; }
    Mod+Shift+Left hotkey-overlay-title="Move Left" { move-column-left; }
    Mod+Shift+Down hotkey-overlay-title="Move Down" { move-window-down; }
    Mod+Shift+Up hotkey-overlay-title="Move Up" { move-window-up; }
    Mod+Shift+Right hotkey-overlay-title="Move Right" { move-column-right; }

    Mod+Shift+H hotkey-overlay-title="Focus Monitor Left" { focus-monitor-left; }
    Mod+Shift+J hotkey-overlay-title="Focus Monitor Down" { focus-monitor-down; }
    Mod+Shift+K hotkey-overlay-title="Focus Monitor Up" { focus-monitor-up; }
    Mod+Shift+L hotkey-overlay-title="Focus Monitor Right" { focus-monitor-right; }
    Mod+Ctrl+Left hotkey-overlay-title="Focus Monitor Left" { focus-monitor-left; }
    Mod+Ctrl+Down hotkey-overlay-title="Focus Monitor Down" { focus-monitor-down; }
    Mod+Ctrl+Up hotkey-overlay-title="Focus Monitor Up" { focus-monitor-up; }
    Mod+Ctrl+Right hotkey-overlay-title="Focus Monitor Right" { focus-monitor-right; }
    Mod+Ctrl+Shift+Left hotkey-overlay-title="Move to Monitor Left" { move-column-to-monitor-left; }
    Mod+Ctrl+Shift+Down hotkey-overlay-title="Move to Monitor Down" { move-column-to-monitor-down; }
    Mod+Ctrl+Shift+Up hotkey-overlay-title="Move to Monitor Up" { move-column-to-monitor-up; }
    Mod+Ctrl+Shift+Right hotkey-overlay-title="Move to Monitor Right" { move-column-to-monitor-right; }

    Mod+U hotkey-overlay-title="Workspace Down" { focus-workspace-down; }
    Mod+I hotkey-overlay-title="Workspace Up" { focus-workspace-up; }
    Mod+Page_Down hotkey-overlay-title="Workspace Down" { focus-workspace-down; }
    Mod+Page_Up hotkey-overlay-title="Workspace Up" { focus-workspace-up; }
    Mod+Ctrl+U hotkey-overlay-title="Move to Workspace Down" { move-column-to-workspace-down; }
    Mod+Ctrl+I hotkey-overlay-title="Move to Workspace Up" { move-column-to-workspace-up; }
    Mod+Shift+Page_Down hotkey-overlay-title="Move Workspace Down" { move-workspace-down; }
    Mod+Shift+Page_Up hotkey-overlay-title="Move Workspace Up" { move-workspace-up; }
    Mod+Shift+U hotkey-overlay-title="Move Workspace Down" { move-workspace-down; }
    Mod+Shift+I hotkey-overlay-title="Move Workspace Up" { move-workspace-up; }

    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp cooldown-ms=150 { move-column-to-workspace-up; }
    Mod+Shift+WheelScrollDown { focus-column-right; }
    Mod+Shift+WheelScrollUp { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp { move-column-left; }

    Mod+Home hotkey-overlay-title="Focus First Column" { focus-column-first; }
    Mod+End hotkey-overlay-title="Focus Last Column" { focus-column-last; }
    Mod+Ctrl+Home hotkey-overlay-title="Move to First Column" { move-column-to-first; }
    Mod+Ctrl+End hotkey-overlay-title="Move to Last Column" { move-column-to-last; }

    Mod+W hotkey-overlay-title="Toggle Tabbed Column" { toggle-column-tabbed-display; }
    Mod+BracketLeft hotkey-overlay-title="Stack/Unstack Left" { consume-or-expel-window-left; }
    Mod+BracketRight hotkey-overlay-title="Stack/Unstack Right" { consume-or-expel-window-right; }
    Mod+Period hotkey-overlay-title="Unstack Window" { expel-window-from-column; }
    Mod+R hotkey-overlay-title="Cycle Column Width" { switch-preset-column-width; }
    Mod+Shift+R hotkey-overlay-title="Cycle Window Height" { switch-preset-window-height; }
    Mod+Ctrl+R hotkey-overlay-title="Reset Window Height" { reset-window-height; }
    Mod+Ctrl+F hotkey-overlay-title="Expand Column" { expand-column-to-available-width; }
    Mod+C hotkey-overlay-title="Center Column" { center-column; }
    Mod+Ctrl+C hotkey-overlay-title="Center Visible Columns" { center-visible-columns; }
    Mod+Backspace hotkey-overlay-title="Maximize Column" { maximize-column; }
    Mod+Shift+F hotkey-overlay-title="Fullscreen Window" { fullscreen-window; }
    Mod+Minus hotkey-overlay-title="Narrow Column" { set-column-width "-10%"; }
    Mod+Equal hotkey-overlay-title="Widen Column" { set-column-width "+10%"; }
    Mod+Shift+Minus hotkey-overlay-title="Shorten Window" { set-window-height "-10%"; }
    Mod+Shift+Equal hotkey-overlay-title="Taller Window" { set-window-height "+10%"; }
    Mod+Shift+V hotkey-overlay-title="Toggle Floating" { toggle-window-floating; }

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    Print repeat=false hotkey-overlay-title="Screenshot Region" { spawn-sh "noctalia msg screenshot-region"; }
    Mod+Shift+S repeat=false hotkey-overlay-title="Screenshot Region" { spawn-sh "noctalia msg screenshot-region"; }
    Ctrl+Print repeat=false hotkey-overlay-title="Screenshot Screen" { spawn-sh "noctalia msg screenshot-fullscreen pick"; }
    Alt+Print hotkey-overlay-title="Screenshot Window" { screenshot-window; }
    Mod+Escape allow-inhibiting=false hotkey-overlay-title="Toggle Shortcut Inhibit" { toggle-keyboard-shortcuts-inhibit; }
    Mod+Shift+E hotkey-overlay-title="Quit Niri" { quit; }
    Mod+Shift+P hotkey-overlay-title="Power Off Monitors" { power-off-monitors; }
}
