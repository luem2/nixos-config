[
  {
    "bindings": {
      "ctrl-e": "workspace::ToggleRightDock",
      "ctrl-b": "workspace::ToggleLeftDock",
      "ctrl-shift-d": "debug_panel::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space d b": "editor::ToggleBreakpoint",
      "space d d": "debugger::ClearAllBreakpoints",
      "space d c": "debugger::Continue",
      "space d i": "debugger::StepInto",
      "space d o": "debugger::StepOut",
      "space d n": "debugger::StepOver",
      "space d r": "debugger::Restart",
      "space d s": "debugger::Stop"
    }
  },
  {
    "context": "(Dock || Editor || ProjectPanel) && !(Picker > Editor)",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-a": "editor::SelectAll"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-1": ["pane::ActivateItem", 0],
      "ctrl-2": ["pane::ActivateItem", 1],
      "ctrl-3": ["pane::ActivateItem", 2],
      "ctrl-4": ["pane::ActivateItem", 3],
      "ctrl-5": ["pane::ActivateItem", 4],
      "ctrl-6": ["pane::ActivateItem", 5],
      "ctrl-7": ["pane::ActivateItem", 6],
      "ctrl-8": ["pane::ActivateItem", 7],
      "ctrl-9": ["pane::ActivateItem", 8],
      "ctrl-0": "pane::ActivateLastItem"
    }
  },
  {
    "context": "Editor && mode == full && vim_mode == normal && !menu",
    "bindings": {
      "ctrl-k": null
    }
  },
  {
    "context": "(Editor && mode == full && vim_mode == normal && !menu) || EmptyPane",
    "bindings": {
      "ctrl-k ctrl-o": "workspace::Open",
      "ctrl-o": null
    }
  }
]
